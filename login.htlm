<!DOCTYPE html>
<html>
<head>
<title>Login - Nightfire Plus</title>

<style>
body {
  margin: 0;
  background: #111;
  color: orange;
  font-family: Arial;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

/* LOGIN CARD */
.login-card {
  background: #000;
  padding: 30px;
  border-radius: 15px;
  border: 1px solid orange;
  text-align: center;
  box-shadow: 0 0 15px orange;
}

input {
  padding: 10px;
  width: 200px;
  margin-bottom: 15px;
  border: none;
  outline: none;
}

button {
  background: black;
  color: orange;
  border: 1px solid orange;
  padding: 10px;
  cursor: pointer;
}

button:hover {
  box-shadow: 0 0 10px orange;
}
</style>
</head>

<body>

<div class="login-card">
  <h2>Enter Your Name</h2>
  <input type="text" id="nameInput" placeholder="Username">
  <br>
  <button onclick="saveUser()">Enter</button>
</div>

<script>
function saveUser() {
  const name = document.getElementById("nameInput").value;
  if (name) {
    localStorage.setItem("nf_user", name);
    window.location.href = "index.html";
  }
}
</script>

</body>
</html>
